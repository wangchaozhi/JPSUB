{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jpsub",
  "version": "0.1.0",
  "identifier": "com.jpsub.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "日语视频转中文字幕",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/engine"],
    "resources": ["binaries"]
  }
}
